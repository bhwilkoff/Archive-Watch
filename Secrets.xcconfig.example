// Copy this file to `Secrets.xcconfig` and fill in your keys. The real file
// is gitignored. Xcode reads it via the tvOS target's Debug + Release
// configurations. Python enrichment scripts (`tools/enrich_artwork.py`)
// read the same file via tools/enrich_artwork.py:load_secret().

// TMDb v4 bearer token (primary metadata + artwork source).
// Register at https://www.themoviedb.org/settings/api (v4 → "API Read Access Token").
TMDB_BEARER_TOKEN = your-tmdb-v4-bearer-token-here

// Fanart.tv personal API key (gap-fills designed movie posters when TMDb
// doesn't have one). Register at https://fanart.tv/get-an-api-key.
// Optional — enrichment skips this pass cleanly if the key is missing.
FANART_TV_KEY = your-fanart-tv-key-here

// OMDb API key (another IMDb-keyed designed-poster source — Amazon-hosted
// promotional art). Register at https://www.omdbapi.com/apikey.aspx.
// Free tier: 1000 req/day. Optional — skipped cleanly if missing.
OMDB_KEY = your-omdb-key-here
